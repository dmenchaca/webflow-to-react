<?xml version="1.0" encoding="UTF-8"?>
<!-- Copy to web/public/sitemap.xml — served at /sitemap.xml
     Replace loc URLs with real production HTTPS URLs and routes you deploy.
     See gotchas.md § Static sitemap.xml and robots.txt -->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://www.example.com/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
</urlset>
